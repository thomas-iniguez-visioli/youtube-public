{
  "name": "youtube",
  "version": "1.13.0",
  "type": "module",
  "description": "youtube local",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "build": "bun i helmet cors && bun x electron-rebuild -y  ",
    "prepush": "bun test",
    "postpush": "gh signoff",
    "start": "electron .",
    "test": "bun test ./tests/*.test.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "axios": "^1.7.9",
    "cors": "^2.8.6",
    "ejs": "^3.1.10",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "escape-html": "^1.0.3",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "rollbar": "^2.26.5",
    "socket.io": "^4.4.1",
    "unzipper": "^0.12.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^25.1.8",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "electron",
    "video",
    "streaming",
    "node"
  ],
  "author": "arbinger",
  "license": "MIT",
  "build": {
    "appId": "com.arbinger.youtube",
    "win": {
      "target": [
        "NSIS",
        "portable",
        "zip"
      ],
      "publish": [
        "github"
      ]
    },
    "mac": {
      "target": "dmg",
      "publish": [
        "github"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "publish": [
        "github"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "thomas-iniguez-visioli",
        "repo": "youtube-public",
        "releaseType": "draft"
      }
    ]
  }
}

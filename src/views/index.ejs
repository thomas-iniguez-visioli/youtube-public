<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>YouTube Downloader - Ma Bibliothèque</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Plyr CSS -->
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
    <!-- Fuse.js for fuzzy search -->
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

    <script src="https://cdn.lr-ingest.com/LogRocket.min.js" crossorigin="anonymous"></script>
    <script>window.LogRocket && window.LogRocket.init('kw8sds/youtube-zozss');</script>
    <script src="renderer.js"></script>
    <script src="socket.io.js"></script>

    <script>
        // Socket.io initialization
        if (typeof io !== 'undefined') {
            const socket = io();
            socket.on('error-notification', (data) => {
                alert("Erreur : " + data.message);
            });

            socket.on('download-finished', (data) => {
                const toastVideoTitle = document.getElementById('toastVideoTitle');
                const toastWatchBtn = document.getElementById('toastWatchBtn');
                const downloadToast = document.getElementById('downloadToast');
                
                if (toastVideoTitle && toastWatchBtn && downloadToast) {
                    toastVideoTitle.textContent = data.title;
                    toastWatchBtn.href = `/watch?id=${data.videoId}`;
                    
                    const toast = new bootstrap.Toast(downloadToast);
                    toast.show();
                }
            });

            socket.on('db-updated', () => {
                console.log('Database updated, consider refreshing or updating UI');
            });
        }
    </script>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="downloadToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-primary text-white">
                <strong class="me-auto">Téléchargement terminé</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                <span id="toastVideoTitle" class="fw-bold"></span> est maintenant disponible.
                <div class="mt-2 pt-2 border-top">
                    <a id="toastWatchBtn" href="#" class="btn btn-primary btn-sm">Regarder</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        :root {
            --bg-color: #080808;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-hover: rgba(255, 255, 255, 0.08);
            --text-color: #f1f1f1;
            --accent-color: #3ea6ff;
            --card-radius: 16px;
            --blur-amount: 15px;
            --nav-bg: rgba(8, 8, 8, 0.7);
        }
        body {
            background: radial-gradient(circle at top right, rgba(62, 166, 255, 0.05), transparent 600px),
                        radial-gradient(circle at bottom left, rgba(255, 0, 0, 0.03), transparent 600px),
                        #080808;
            color: var(--text-color);
            font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }
        .navbar {
            background-color: var(--nav-bg) !important;
            backdrop-filter: blur(var(--blur-amount));
            -webkit-backdrop-filter: blur(var(--blur-amount));
            border-bottom: 1px solid var(--glass-border);
            padding: 0.8rem 1rem;
        }
        .video-card {
            background: var(--glass-bg);
            backdrop-filter: blur(5px);
            border: 1px solid var(--glass-border);
            border-radius: var(--card-radius);
            margin-bottom: 2rem;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            padding: 10px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        .video-card:hover {
            background: var(--glass-hover);
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            color: var(--text-color);
        }
        .video-thumbnail-container {
            overflow: hidden;
            border-radius: calc(var(--card-radius) - 6px);
            aspect-ratio: 16/9;
            position: relative;
        }
        .video-thumbnail {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
            border-radius: calc(var(--card-radius) - 6px);
        }
        .video-card:hover .video-thumbnail {
            transform: scale(1.08);
        }
        .video-info {
            display: flex;
            margin-top: 15px;
            flex-grow: 1;
        }
        .video-details {
            width: 100%;
        }
        .video-title {
            font-size: 0.95rem;
            font-weight: 500;
            line-height: 1.3rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-bottom: 8px;
            transition: color 0.2s;
            height: 2.6rem;
        }
        .video-card:hover .video-title {
            color: var(--accent-color);
        }
        .video-meta {
            font-size: 0.8rem;
            color: #aaaaaa;
        }
        .tag-badge {
            background-color: rgba(255, 255, 255, 0.05);
            color: #ffffff;
            font-size: 0.7rem;
            padding: 3px 8px;
            border-radius: 6px;
            margin-right: 4px;
            cursor: pointer;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.2s;
        }
        .tag-badge:hover {
            background-color: rgba(255, 255, 255, 0.15);
            border-color: var(--accent-color);
        }
        .search-container {
            max-width: 600px;
        }
        .form-control {
            background-color: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(5px);
            border: 1px solid var(--glass-border);
            color: var(--text-color);
            border-radius: 20px !important;
            padding: 0.6rem 1.2rem;
            transition: all 0.3s ease;
        }
        .form-control:focus {
            background-color: rgba(255, 255, 255, 0.08);
            border-color: var(--accent-color);
            color: white;
            box-shadow: 0 0 15px rgba(62, 166, 255, 0.2);
        }
        .btn {
            border-radius: 20px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            backdrop-filter: blur(5px);
            font-weight: 500;
            text-transform: none;
            font-size: 0.9rem;
        }
        .btn-outline-light {
            border-color: var(--glass-border);
            background: rgba(255, 255, 255, 0.03);
        }
        .btn-outline-light:hover {
            background-color: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
        }
        .tag-filter-section {
            padding: 20px 0;
            margin-bottom: 25px;
            display: flex;
            overflow-x: auto;
            white-space: nowrap;
            gap: 12px;
            scrollbar-width: none;
        }
        .tag-filter-section::-webkit-scrollbar {
            display: none;
        }
        .filter-chip {
            background-color: var(--glass-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            color: var(--text-color);
            padding: 8px 20px;
            border-radius: 25px;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
        }
        .filter-chip.active {
            background: var(--accent-color);
            border-color: var(--accent-color);
            color: white;
            box-shadow: 0 5px 15px rgba(62, 166, 255, 0.3);
        }
        .filter-chip:hover:not(.active) {
            background-color: var(--glass-hover);
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }
        .card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--blur-amount));
            border: 1px solid var(--glass-border);
            border-radius: var(--card-radius);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="https://www.youtube.com/favicon.ico" width="30" height="30" class="me-2" alt="">
                <div class="d-flex flex-column">
                    <strong>YouTube Downloader</strong>
                    <span style="font-size: 0.65rem; color: #aaaaaa; margin-top: -5px;">v<%= typeof appVersion !== 'undefined' ? appVersion : '' %></span>
                </div>
            </a>
            
            <div class="d-flex flex-grow-1 justify-content-center mx-4">
                <form id="commandForm" class="d-flex w-100 search-container m-0 flex-column">
                    <div class="d-flex w-100">
                        <input class="form-control me-2 rounded-pill ps-4" type="text" id="commandInput" placeholder="Coller une URL YouTube..." required>
                        <button class="btn btn-outline-light rounded-pill px-4" type="submit">Télécharger</button>
                    </div>
                    <small class="text-muted text-center mt-1" style="font-size: 0.65rem; color: #777 !important;">Fichier backlog : <%= typeof backlogFile !== 'undefined' ? backlogFile : '' %></small>
                </form>
            </div>
            <div class="d-flex">
                <a href="/favorites" class="btn btn-outline-danger rounded-pill px-4 me-2">Favoris (<%= typeof favoritesCount !== 'undefined' ? favoritesCount : 0 %>)</a>
                <a href="/queue" class="btn btn-outline-success rounded-pill px-4 me-2">File (<%= typeof queueCount !== 'undefined' ? queueCount : 0 %>)</a>
                <a href="/playlists" class="btn btn-outline-warning rounded-pill px-4 me-2">Playlists</a>
                <a href="/history" class="btn btn-outline-info rounded-pill px-4">Historique (<%= typeof historyCount !== 'undefined' ? historyCount : 0 %>/<%= typeof historyLimit !== 'undefined' ? historyLimit : 0 %>)</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4">
        <div class="row mt-3">
            <div class="col-md-6 offset-md-3">
                <input type="text" id="fuzzySearchInput" class="form-control rounded-pill ps-4 bg-dark text-white border-secondary" placeholder="🔍 Rechercher dans votre bibliothèque (titre, uploader...)" autocomplete="off">
            </div>
        </div>
        
        <% if (typeof channel !== 'undefined' && channel) { %>
            <div class="d-flex align-items-center mb-4 mt-3">
                <h2 class="text-white"><%= channel %></h2>
                <% if (typeof channelUrl !== 'undefined' && channelUrl) { %>
                    <button class="btn btn-primary btn-sm ms-3" onclick="downloadChannel(<%- JSON.stringify(channelUrl || '').replace(/\"/g, '&quot;') %>)">Télécharger la chaîne</button>
                <% } %>
                <% if (channel.startsWith('Playlist : ')) { %>
                    <a href="/playlist/delete?name=<%= encodeURIComponent(channel.replace('Playlist : ', '')) %>" class="btn btn-danger btn-sm ms-3" onclick="return confirm('Supprimer cette playlist ?')">Supprimer la playlist</a>
                <% } %>
                <% if (channel === "Ma File d'attente") { %>
                    <a href="/queue/clear" class="btn btn-danger btn-sm ms-3" onclick="return confirm('Vider la file d\\'attente ?')">Vider la file</a>
                <% } %>
                <a href="/" class="btn btn-outline-secondary btn-sm ms-3">Retour à l'accueil</a>
            </div>
        <% } %>

        <% if (channel === "Mes Playlists") { %>
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card bg-dark text-white border-secondary">
                        <div class="card-body">
                            <h5 class="card-title">Créer une playlist</h5>
                            <form action="/playlist/create" method="POST" class="d-flex">
                                <input type="text" name="name" class="form-control form-control-sm bg-dark text-white border-secondary me-2" placeholder="Nom de la playlist" required>
                                <button type="submit" class="btn btn-primary btn-sm">Créer</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <% playlists.forEach(function(playlist) { %>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-2 mb-4">
                        <a href="/playlist?name=<%= encodeURIComponent(playlist.name) %>" class="text-decoration-none">
                            <div class="card bg-dark text-white border-secondary h-100">
                                <div class="card-body d-flex flex-column justify-content-center align-items-center" style="height: 150px; background: #272727; border-radius: 8px;">
                                    <h5 class="text-center"><%= playlist.name %></h5>
                                    <span class="badge bg-secondary"><%= playlist.videoIds.length %> vidéos</span>
                                </div>
                            </div>
                        </a>
                    </div>
                <% }); %>
            </div>
        <% } %>
        <!-- Section Filtres Inline -->
        <div class="tag-filter-section">
            <div class="filter-chip active" onclick="filterByTag('all', this)">Tous</div>
            <% if (typeof allTags !== 'undefined') { %>
                <% allTags.forEach(function(tag){ %>
                    <div class="filter-chip" onclick="filterByTag('<%= tag.replace(/'/g, "\\'") %>', this)"><%= tag %></div>
                <% }); %>
            <% } %>
            <% if (typeof allChannels !== 'undefined') { %>
                <% allChannels.forEach(function(uploader){ %>
                    <div class="filter-chip" onclick="filterByChannel('<%= uploader.replace(/'/g, "\\'") %>', this)"><%= uploader %></div>
                <% }); %>
            <% } %>
        </div>

        <div class="row" id="resultsList">
            <!-- Les vidéos seront chargées ici par JavaScript pour économiser la mémoire -->
        </div>
        <div class="text-center my-4" id="loadMoreContainer">
            <button id="loadMoreBtn" class="btn btn-outline-primary rounded-pill px-5">Charger plus de vidéos</button>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Données des vidéos passées par le serveur
        const allVideos = <%- JSON.stringify(results) %>;
        const channel = <%- JSON.stringify(channel) %>;
        const itemsPerPage = 24;
        let currentPage = 0;
        let filteredVideos = [...allVideos];

        const resultsList = document.getElementById('resultsList');
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        const loadMoreContainer = document.getElementById('loadMoreContainer');
        const searchInput = document.getElementById('fuzzySearchInput');

        function renderVideos(append = false) {
            if (!append) {
                resultsList.innerHTML = '';
                currentPage = 0;
            }

            const start = currentPage * itemsPerPage;
            const end = start + itemsPerPage;
            const pageVideos = filteredVideos.slice(start, end);

            pageVideos.forEach(result => {
                let playlistParam = '';
                if (channel) {
                    if (channel.startsWith('Playlist : ')) {
                        playlistParam = '&playlist=' + encodeURIComponent(channel.replace('Playlist : ', '')).replace(/'/g, "%27");
                    } else if (channel !== 'Mes Playlists' && channel !== 'Historique') {
                        playlistParam = '&playlist=' + encodeURIComponent('Channel: ' + channel).replace(/'/g, "%27");
                    }
                }

                const col = document.createElement('div');
                col.className = 'col-12 col-sm-6 col-md-4 col-lg-3 col-xl-2 video-item';
                col.setAttribute('data-tags', result.tags.join(','));
                
                let tagsHtml = result.tags.map(tag => `<span class="tag-badge">${tag}</span>`).join('');
                let actionBtns = '';
                
                if (channel && channel.startsWith('Playlist : ')) {
                    actionBtns += `<button class="btn btn-sm btn-outline-warning" onclick="event.stopPropagation(); if(confirm('Retirer de la playlist ?')) window.location.href='/playlist/remove?name=${encodeURIComponent(channel.replace('Playlist : ', '')).replace(/'/g, "\\'")}&videoId=${result.yid}'">Retirer</button>`;
                }
                if (channel === "Ma File d'attente") {
                    actionBtns += `<button class="btn btn-sm btn-outline-warning" onclick="event.stopPropagation(); window.location.href='/queue/remove?id=${result.yid}'">Retirer</button>`;
                } else {
                    actionBtns += `<button class="btn btn-sm btn-outline-success" onclick="event.stopPropagation(); addToQueue('${result.yid}')">File</button>`;
                }
                actionBtns += `<button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); toggleFavorite('${result.yid}', this)">❤</button>`;
                actionBtns += `<button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); if(confirm('Supprimer cette vidéo ?')) window.location.href='/delete?id=${result.yid}'">Supprimer</button>`;

                col.innerHTML = `
                    <div class="video-card" onclick="location.href='/watch?id=${result.yid}${playlistParam}'">
                        <img src="https://img.youtube.com/vi/${result.yid}/hqdefault.jpg" class="video-thumbnail" alt="Thumbnail">
                        <div class="video-info">
                            <div class="video-details w-100">
                                <div class="video-title text-white">${result.fileName}</div>
                                <div class="video-meta">
                                    ${result.uploader ? `
                                        <div class="mb-1">
                                            <a href="/channel?name=${encodeURIComponent(result.uploader)}" onclick="event.stopPropagation();" style="color: #aaaaaa; text-decoration: none; font-size: 0.85rem;">
                                                ${result.uploader}
                                            </a>
                                        </div>
                                    ` : ''}
                                    ${tagsHtml}
                                </div>
                                <div class="mt-2 d-flex gap-1">
                                    ${actionBtns}
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                resultsList.appendChild(col);
            });

            if (end >= filteredVideos.length) {
                loadMoreContainer.style.display = 'none';
            } else {
                loadMoreContainer.style.display = 'block';
            }
        }

        loadMoreBtn.addEventListener('click', () => {
            currentPage++;
            renderVideos(true);
        });

        // Initialize Fuse.js for search
        const fuse = new Fuse(allVideos, {
            keys: ['fileName', 'uploader'],
            threshold: 0.3,
            distance: 100,
            ignoreLocation: true
        });

        searchInput.addEventListener('input', function() {
            const query = this.value.trim();
            
            if (query.length === 0) {
                filteredVideos = [...allVideos];
            } else {
                const results = fuse.search(query);
                filteredVideos = results.map(r => r.item);
            }
            renderVideos();
        });

        function filterByTag(tag, element) {
            document.querySelectorAll('.filter-chip').forEach(chip => chip.classList.remove('active'));
            element.classList.add('active');

            if (tag === 'all') {
                filteredVideos = [...allVideos];
            } else {
                filteredVideos = allVideos.filter(v => v.tags.includes(tag));
            }
            renderVideos();
        }

        function filterByChannel(uploader, element) {
            document.querySelectorAll('.filter-chip').forEach(chip => chip.classList.remove('active'));
            element.classList.add('active');

            if (uploader === 'all') {
                filteredVideos = [...allVideos];
            } else {
                filteredVideos = allVideos.filter(v => v.uploader === uploader);
            }
            renderVideos();
        }

        async function addToQueue(videoId) {
            try {
                const response = await fetch(`/queue/add?id=${videoId}`, {
                    headers: { 'Accept': 'application/json' }
                });
                const data = await response.json();
                if (data.success) {
                    const queueBtn = document.querySelector('a[href="/queue"]');
                    if (queueBtn) {
                        queueBtn.textContent = `File (${data.queueCount})`;
                    }
                }
            } catch (err) {
                console.error("Erreur ajout file :", err);
            }
        }

        async function toggleFavorite(videoId, btn) {
            try {
                const response = await fetch(`/favorite/toggle?id=${videoId}`, {
                    headers: { 'Accept': 'application/json' }
                });
                const data = await response.json();
                if (data.success) {
                    const favBtn = document.querySelector('a[href="/favorites"]');
                    if (favBtn) {
                        favBtn.textContent = `Favoris (${data.favoritesCount})`;
                    }
                    if (data.isFavorite) {
                        btn.classList.remove('btn-outline-danger');
                        btn.classList.add('btn-danger');
                    } else {
                        btn.classList.remove('btn-danger');
                        btn.classList.add('btn-outline-danger');
                        // Si on est sur la page des favoris, on retire l'élément de la liste
                        if (channel === "Mes Favoris") {
                            btn.closest('.video-item').remove();
                        }
                    }
                }
            } catch (err) {
                console.error("Erreur toggle favori :", err);
            }
        }

        // Initial render
        renderVideos();

        // Gestion du retour à la dernière page visitée
        (function() {
            const lastUrlKey = 'last_visited_url';
            const sessionNavKey = 'has_navigated_this_session';
            const currentUrl = window.location.href;
            const lastUrl = localStorage.getItem(lastUrlKey);

            // Si on est sur l'accueil, qu'on a une URL sauvegardée différente, 
            // et que c'est le début de la session (pas encore navigué)
            if (window.location.pathname === '/' && 
                lastUrl && 
                lastUrl !== currentUrl && 
                !sessionStorage.getItem(sessionNavKey)) {
                
                sessionStorage.setItem(sessionNavKey, 'true');
                window.location.href = lastUrl;
                return;
            }

            // Marquer comme navigué et sauvegarder l'URL actuelle
            sessionStorage.setItem(sessionNavKey, 'true');
            localStorage.setItem(lastUrlKey, currentUrl);
        })();

        function downloadChannel(url) {
            if (window.electronAPI && window.electronAPI.setTitle) {
                window.electronAPI.setTitle(url);
                alert("Téléchargement de la chaîne lancé !");
            } else {
                window.location.href = `/download?url=${encodeURIComponent(url)}`;
            }
        }

        // Le téléchargement est géré par renderer.js via IPC.
        // On peut ajouter un fallback au cas où renderer.js ne se charge pas correctement.
        const commandForm = document.getElementById('commandForm');
        commandForm.addEventListener('submit', (e) => {
            // Si window.electronAPI n'existe pas, on utilise la route Express classique
            if (!window.electronAPI) {
                e.preventDefault();
                const url = document.getElementById('commandInput').value;
                window.location.href = `/download?url=${encodeURIComponent(url)}`;
            }
        });
    </script>

    <!-- Tawk.to Script -->
    <script type="text/javascript">
        var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
        (function(){
            var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
            s1.async=true;
            s1.src='https://embed.tawk.to/673f4ae72480f5b4f5a1dbce/1id7jp68o';
            s1.charset='UTF-8';
            s1.setAttribute('crossorigin','*');
            s0.parentNode.insertBefore(s1,s0);
        })();
    </script>
</body>
</html>

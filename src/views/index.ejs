<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>YouTube Downloader - Ma Bibliothèque</title>
    
    <!-- Bootstrap CSS -->
    <link href="/bootstrap.min.css" rel="stylesheet">
    <!-- Plyr CSS -->
    <link rel="stylesheet" href="/plyr.css" />
    <!-- Fuse.js for fuzzy search -->
    <script src="/fuse.js"></script>
    <!-- Roboto Font -->
    <link href="/roboto.css" rel="stylesheet">

    <script src="socket.io.js"></script>
    <script src="renderer.js"></script>

    <link rel="stylesheet" href="/style.css">


    <script>
        // Socket.io and shared utilities are initialized in renderer.js
    </script>

</head>
<body>
    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060;">
    </div>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/favicon.ico" width="30" height="30" class="me-2" alt="">
                <div class="d-flex flex-column">
                    <strong>YouTube Downloader</strong>
                    <span style="font-size: 0.65rem; color: #aaaaaa; margin-top: -5px;">v<%= typeof appVersion !== 'undefined' ? appVersion : '' %></span>
                </div>
            </a>
            
            <div class="d-flex flex-grow-1 justify-content-center mx-4">
                <form id="commandForm" class="d-flex w-100 search-container m-0 flex-column">
                    <div class="d-flex w-100 align-items-center">
                        <input class="form-control me-2 rounded-pill ps-4" type="text" id="commandInput" placeholder="Coller une URL YouTube..." required>
                        <button class="btn btn-outline-light rounded-pill px-4" type="submit">Télécharger</button>
                        <button type="button" class="btn btn-outline-secondary rounded-pill ms-2" title="Changer le dossier de téléchargement" onclick="changeFolder()">📂</button>
                    </div>
                    <small class="text-muted text-center mt-1" style="font-size: 0.65rem; color: #777 !important;">Fichier backlog : <%= typeof backlogFile !== 'undefined' ? backlogFile : '' %></small>
                </form>
            </div>
            <div class="d-flex">
                <a href="/suggestions" class="btn btn-outline-primary rounded-pill px-4 me-2">✨ Suggestions</a>
                <a href="/favorites" class="btn btn-outline-danger rounded-pill px-4 me-2">Favoris (<%= typeof favoritesCount !== 'undefined' ? favoritesCount : 0 %>)</a>
                <a href="/queue" class="btn btn-outline-success rounded-pill px-4 me-2">File (<%= typeof queueCount !== 'undefined' ? queueCount : 0 %>)</a>
                <a href="/playlists" class="btn btn-outline-warning rounded-pill px-4 me-2">Playlists</a>
                <a href="/history" class="btn btn-outline-info rounded-pill px-4">Historique (<%= typeof historyCount !== 'undefined' ? historyCount : 0 %>/<%= typeof historyLimit !== 'undefined' ? historyLimit : 0 %>)</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4">
        <div class="row mt-3">
            <div class="col-md-6 offset-md-3">
                <input type="text" id="fuzzySearchInput" class="form-control rounded-pill ps-4 bg-dark text-white border-secondary" placeholder="🔍 Rechercher dans votre bibliothèque (titre, uploader...)" autocomplete="off">
            </div>
        </div>
        
        <% if (typeof channel !== 'undefined' && channel) { %>
            <div class="d-flex align-items-center mb-4 mt-3">
                <h2 class="text-white"><%= channel %></h2>
                <% if (typeof channelUrl !== 'undefined' && channelUrl) { %>
                    <button class="btn btn-primary btn-sm ms-3" onclick="downloadChannel(<%- JSON.stringify(channelUrl || '').replace(/\"/g, '&quot;') %>)">Télécharger la chaîne</button>
                <% } %>
                <% if (channel.startsWith('Playlist : ')) { %>
                    <a href="/playlist/delete?name=<%= encodeURIComponent(channel.replace('Playlist : ', '')) %>" class="btn btn-danger btn-sm ms-3" onclick="return confirm('Supprimer cette playlist ?')">Supprimer la playlist</a>
                <% } %>
                <% if (channel === "Ma File d'attente") { %>
                    <a href="/queue/clear" class="btn btn-danger btn-sm ms-3" onclick="return confirm('Vider la file d\\'attente ?')">Vider la file</a>
                <% } %>
                <a href="/" class="btn btn-outline-secondary btn-sm ms-3">Retour à l'accueil</a>
            </div>
        <% } %>

        <% if (channel === "Mes Playlists") { %>
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card bg-dark text-white border-secondary">
                        <div class="card-body">
                            <h5 class="card-title">Créer une playlist</h5>
                            <form action="/playlist/create" method="POST" class="d-flex">
                                <input type="text" name="name" class="form-control form-control-sm bg-dark text-white border-secondary me-2" placeholder="Nom de la playlist" required>
                                <button type="submit" class="btn btn-primary btn-sm">Créer</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <% playlists.forEach(function(playlist) { %>
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-2 mb-4">
                        <a href="/playlist?name=<%= encodeURIComponent(playlist.name) %>" class="text-decoration-none">
                            <div class="card bg-dark text-white border-secondary h-100">
                                <div class="card-body d-flex flex-column justify-content-center align-items-center" style="height: 150px; background: #272727; border-radius: 8px;">
                                    <h5 class="text-center"><%= playlist.name %></h5>
                                    <span class="badge bg-secondary"><%= playlist.videoIds.length %> vidéos</span>
                                </div>
                            </div>
                        </a>
                    </div>
                <% }); %>
            </div>
        <% } %>
        <!-- Section Filtres Inline -->
        <div class="tag-filter-section">
            <div class="filter-chip active" onclick="filterByTag('all', this)">Tous</div>
            <% if (typeof allTags !== 'undefined') { %>
                <% allTags.forEach(function(tag){ %>
                    <div class="filter-chip" onclick="filterByTag('<%= tag.replace(/\\/g, "\\\\").replace(/'/g, "\\'") %>', this)"><%= tag %></div>
                <% }); %>
            <% } %>
            <% if (typeof allChannels !== 'undefined') { %>
                <% allChannels.forEach(function(uploader){ %>
                    <div class="filter-chip" onclick="filterByChannel('<%= uploader.replace(/\\/g, "\\\\").replace(/'/g, "\\'") %>', this)"><%= uploader %></div>
                <% }); %>
            <% } %>
        </div>

        <div class="row" id="resultsList">
            <!-- Les vidéos seront chargées ici par JavaScript pour économiser la mémoire -->
        </div>
        <div class="text-center my-4" id="loadMoreContainer">
            <button id="loadMoreBtn" class="btn btn-outline-primary rounded-pill px-5">Charger plus de vidéos</button>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="/bootstrap.bundle.min.js"></script>

    <script>
        // Données des vidéos passées par le serveur
        const allVideos = <%- JSON.stringify(results) %>;
        const channel = <%- JSON.stringify(channel) %>;
        const itemsPerPage = 24;
        let currentPage = 0;
        let filteredVideos = [...allVideos];

        const resultsList = document.getElementById('resultsList');
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        const loadMoreContainer = document.getElementById('loadMoreContainer');
        const searchInput = document.getElementById('fuzzySearchInput');

        function renderVideos(append = false) {
            if (!append) {
                resultsList.innerHTML = '';
                currentPage = 0;
            }

            const start = currentPage * itemsPerPage;
            const end = start + itemsPerPage;
            const pageVideos = filteredVideos.slice(start, end);

            pageVideos.forEach(result => {
                let playlistParam = '';
                if (channel) {
                    if (channel.startsWith('Playlist : ')) {
                        playlistParam = '&playlist=' + encodeURIComponent(channel.replace('Playlist : ', '')).replace(/'/g, "%27");
                    } else if (channel !== 'Mes Playlists' && channel !== 'Historique') {
                        playlistParam = '&playlist=' + encodeURIComponent('Channel: ' + channel).replace(/'/g, "%27");
                    }
                }

                const col = document.createElement('div');
                col.className = 'col-12 col-sm-6 col-md-4 col-lg-3 col-xl-2 video-item';
                col.setAttribute('data-tags', result.tags.join(','));
                
                let tagsHtml = result.tags.map(tag => `<span class="tag-badge">${tag}</span>`).join('');
                let actionBtns = '';
                
                if (channel && channel.startsWith('Playlist : ')) {
                    actionBtns += `<button class="btn btn-sm btn-outline-warning" onclick="event.stopPropagation(); if(confirm('Retirer de la playlist ?')) window.location.href='/playlist/remove?name=${encodeURIComponent(channel.replace('Playlist : ', ''))}&videoId=${result.yid}'">Retirer</button>`;
                }
                if (channel === "Ma File d'attente") {
                    actionBtns += `<button class="btn btn-sm btn-outline-warning" onclick="event.stopPropagation(); window.location.href='/queue/remove?id=${result.yid}'">Retirer</button>`;
                } else {
                    actionBtns += `<button class="btn btn-sm btn-outline-success" onclick="event.stopPropagation(); addToQueue('${result.yid}')">File</button>`;
                }
                actionBtns += `<button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); toggleFavorite('${result.yid}', this)">❤</button>`;
                actionBtns += `<button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); if(confirm('Supprimer cette vidéo ?')) window.location.href='/delete?id=${result.yid}'">Supprimer</button>`;

                col.innerHTML = `
                    <div class="video-card" onclick="location.href='/watch?id=${result.yid}${playlistParam}'">
                        <div class="video-thumb-container">
                            <img data-src="/thumbnail/${result.yid}" src="" class="video-thumbnail lazy" alt="Thumbnail" loading="lazy">
                        </div>
                        <div class="video-info">
                            <div class="video-details w-100">
                                <div class="video-title text-white">${result.fileName}</div>
                                <div class="video-meta">
                                    ${result.uploader ? `
                                        <div class="mb-1">
                                            <a href="/channel?name=${encodeURIComponent(result.uploader)}" onclick="event.stopPropagation();" style="color: #aaaaaa; text-decoration: none; font-size: 0.85rem;">
                                                ${result.uploader}
                                            </a>
                                        </div>
                                    ` : ''}
                                    ${tagsHtml}
                                </div>
                                <div class="mt-2 d-flex gap-1">
                                    ${actionBtns}
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                resultsList.appendChild(col);
            });

            if (end >= filteredVideos.length) {
                loadMoreContainer.style.display = 'none';
            } else {
                loadMoreContainer.style.display = 'block';
            }
        }

        // Initialize Fuse.js for search
        const fuse = new Fuse(allVideos, {
            keys: ['fileName', 'uploader'],
            threshold: 0.3,
            distance: 100,
            ignoreLocation: true
        });

        // Lazy-load thumbnails with IntersectionObserver
        const thumbObserver = new IntersectionObserver((entries, obs) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const img = entry.target;
                    img.src = img.dataset.src;
                    img.classList.remove('lazy');
                    obs.unobserve(img);
                }
            });
        }, { rootMargin: '200px' });

        function observeLazyImages() {
            document.querySelectorAll('img.lazy').forEach(img => thumbObserver.observe(img));
        }

        // Initial render
        renderVideos();
        observeLazyImages();

        loadMoreBtn.addEventListener('click', () => {
            currentPage++;
            renderVideos(true);
            observeLazyImages();
        });

        // Debounced fuzzy search
        searchInput.addEventListener('input', debounce(function() {
            const query = this.value.trim();
            filteredVideos = query.length === 0 ? [...allVideos] : fuse.search(query).map(r => r.item);
            renderVideos();
            observeLazyImages();
        }, 250));

        function filterByTag(tag, element) {
            document.querySelectorAll('.filter-chip').forEach(chip => chip.classList.remove('active'));
            element.classList.add('active');
            filteredVideos = tag === 'all' ? [...allVideos] : allVideos.filter(v => v.tags.includes(tag));
            renderVideos();
            observeLazyImages();
        }

        function filterByChannel(uploader, element) {
            document.querySelectorAll('.filter-chip').forEach(chip => chip.classList.remove('active'));
            element.classList.add('active');
            filteredVideos = uploader === 'all' ? [...allVideos] : allVideos.filter(v => v.uploader === uploader);
            renderVideos();
            observeLazyImages();
        }

        // Gestion du retour à la dernière page visitée
        (function() {
            const lastUrlKey = 'last_visited_url';
            const sessionNavKey = 'has_navigated_this_session';
            const currentUrl = window.location.href;
            const lastUrl = localStorage.getItem(lastUrlKey);

            // Si on est sur l'accueil, qu'on a une URL sauvegardée différente, 
            // et que c'est le début de la session (pas encore navigué)
            if (window.location.pathname === '/' && 
                lastUrl && 
                lastUrl !== currentUrl && 
                !lastUrl.includes('/suggestions') &&
                !sessionStorage.getItem(sessionNavKey)) {
                
                sessionStorage.setItem(sessionNavKey, 'true');
                window.location.href = lastUrl;
                return;
            }

            // Marquer comme navigué et sauvegarder l'URL actuelle
            sessionStorage.setItem(sessionNavKey, 'true');
            localStorage.setItem(lastUrlKey, currentUrl);
        })();

        // Le téléchargement est géré par renderer.js via IPC.
        // On peut ajouter un fallback au cas où renderer.js ne se charge pas correctement.
        const commandForm = document.getElementById('commandForm');
        commandForm.addEventListener('submit', (e) => {
            // Si window.electronAPI n'existe pas, on utilise la route Express classique
            if (!window.electronAPI) {
                e.preventDefault();
                const url = document.getElementById('commandInput').value;
                window.location.href = `/download?url=${encodeURIComponent(url)}`;
            }
        });
    </script>

    <!-- Tawk.to removed (offline mode) -->
</body>
</html>

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    
    <!-- Bootstrap CSS -->
    <link href="/bootstrap.min.css" rel="stylesheet">
    <!-- Plyr CSS -->
    <link rel="stylesheet" href="/plyr.css" />
    <!-- Roboto Font -->
    <link href="/roboto.css" rel="stylesheet">

    <script src="socket.io.js"></script>
    <script src="renderer.js"></script>

    <script>
        // Socket.io and shared utilities are initialized in renderer.js
    </script>


    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1060;">
    </div>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top mb-4">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/favicon.ico" width="30" height="30" class="me-2" alt="">
                <div class="d-flex flex-column">
                    <strong>YouTube Downloader</strong>
                    <span style="font-size: 0.65rem; color: #aaaaaa; margin-top: -5px;">v<%= typeof appVersion !== 'undefined' ? appVersion : '' %></span>
                </div>
            </a>
            
            <div class="d-flex flex-grow-1 justify-content-center mx-4">
                <form id="commandForm" class="d-flex w-100 search-container m-0 flex-column">
                    <div class="d-flex w-100 align-items-center">
                        <input class="form-control me-2 rounded-pill ps-4" type="text" id="commandInput" placeholder="Coller une URL YouTube..." required>
                        <button class="btn btn-outline-light rounded-pill px-4" type="submit">Télécharger</button>
                        <button type="button" class="btn btn-outline-secondary rounded-pill ms-2" title="Changer le dossier de téléchargement" onclick="changeFolder()">📂</button>
                    </div>
                    <small class="text-muted text-center mt-1" style="font-size: 0.65rem; color: #777 !important;">Fichier backlog : <%= typeof backlogFile !== 'undefined' ? backlogFile : '' %></small>
                </form>
            </div>
            <div class="d-flex">
                <a href="/patchnotes" class="btn btn-outline-secondary rounded-pill px-4 me-2">📜 Notes</a>
                <a href="/suggestions" class="btn btn-outline-primary rounded-pill px-4 me-2">✨ Suggestions</a>
                <a href="/favorites" class="btn btn-outline-danger rounded-pill px-4 me-2">Favoris (<%= typeof favoritesCount !== 'undefined' ? favoritesCount : 0 %>)</a>
                <a href="/queue" class="btn btn-outline-success rounded-pill px-4 me-2">File (<%= typeof queueCount !== 'undefined' ? queueCount : 0 %>)</a>
                <a href="/playlists" class="btn btn-outline-warning rounded-pill px-4 me-2">Playlists</a>
                <a href="/history" class="btn btn-outline-info rounded-pill px-4">Historique (<%= typeof historyCount !== 'undefined' ? historyCount : 0 %>/<%= typeof historyLimit !== 'undefined' ? historyLimit : 0 %>)</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid video-container">
        <div class="row">
            <!-- Lecteur Vidéo et Infos -->
            <div class="col-lg-8">
                <div class="plyr__video-embed" id="player">
                    <video id="videoPlayer" controls crossorigin playsinline>
                        <source src="/video/?id=<%= encodeURIComponent(code) %>" type="video/mp4" />
                    </video>
                </div>

                <h1 class="video-title"><%= (typeof videodata !== 'undefined' && videodata.title) ? videodata.title : title %></h1>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="video-meta">
                        <strong><a href="/channel?name=<%= (typeof videodata !== 'undefined' && videodata.uploader) ? encodeURIComponent(videodata.uploader) : '' %>" style="color: #ffffff; text-decoration: none;"><%= (typeof videodata !== 'undefined' && videodata.uploader) ? videodata.uploader : 'Uploader inconnu' %></a></strong> • <%= (typeof videodata !== 'undefined' && videodata.view_count) ? videodata.view_count.toLocaleString() + ' vues' : '' %>
                    </div>
                    <div class="d-flex align-items-center">
                        <button id="favoriteBtn" class="btn <%= isFavorite ? 'btn-danger' : 'btn-outline-danger' %> btn-sm me-2" onclick="toggleFavorite(<%- JSON.stringify(code).replace(/\"/g, '&quot;') %>)">
                            <%= isFavorite ? '❤' : '♡' %> Favori
                        </button>
                        <button class="btn btn-outline-info btn-sm me-2" onclick="shareVideo(<%- JSON.stringify((typeof videodata !== 'undefined' && videodata.webpage_url) ? videodata.webpage_url : ('https://www.youtube.com/watch?v=' + code)).replace(/\"/g, '&quot;') %>)">
                            ↗ Partager
                        </button>
                        <button class="btn btn-outline-success btn-sm me-2" onclick='addToQueue(<%- JSON.stringify(code) %>)'>File d'attente</button>
                        <% if (typeof videodata !== 'undefined' && videodata.uploader && videodata.uploader !== 'Uploader inconnu') { %>
                            <a href="/channel?name=<%= encodeURIComponent(videodata.uploader) %>" class="btn btn-outline-info btn-sm me-2">
                                📺 Voir la chaîne
                            </a>
                        <% } %>
                        <% if (typeof videodata !== 'undefined' && (videodata.channel_url || videodata.uploader_url)) { %>
                            <button class="btn btn-outline-primary btn-sm me-2" onclick="downloadChannel(<%- JSON.stringify(videodata.channel_url || videodata.uploader_url) %>)">
                                📥 Télécharger la chaîne
                            </button>
                        <% } %>
                        <div class="dropdown me-2">
                            <button class="btn btn-outline-warning btn-sm dropdown-toggle" type="button" id="playlistDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                Ajouter à une playlist
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="playlistDropdown">
                                <% playlists.forEach(function(playlist) { %>
                                    <li>
                                        <form action="/playlist/add" method="POST">
                                            <input type="hidden" name="playlistName" value="<%= playlist.name %>">
                                            <input type="hidden" name="videoId" value="<%= code %>">
                                            <button type="submit" class="dropdown-item"><%= playlist.name %></button>
                                        </form>
                                    </li>
                                <% }); %>
                                <% if (playlists.length === 0) { %>
                                    <li><a class="dropdown-item disabled" href="#">Aucune playlist</a></li>
                                <% } %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/playlists">Gérer les playlists</a></li>
                            </ul>
                        </div>
                        <% if (typeof nextVideo !== 'undefined' && nextVideo) { %>
                            <button onclick="playNext()" class="btn btn-outline-primary btn-sm me-2">Vidéo suivante</button>
                        <% } %>
                        <a href="/delete?id=<%= encodeURIComponent(code) %>" class="btn btn-outline-danger btn-sm">Supprimer</a>
                    </div>
                </div>

                <div class="video-description">
                    <p><%= (typeof videodata !== 'undefined') ? videodata.description : '' %></p>
                </div>

                <div class="mt-4">
                    <h5>Ajouter un tag</h5>
                    <form action="/tag" method="post" class="row g-3">
                        <div class="col-auto">
                            <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" id="tagInput" name="tag" placeholder="Tag..." required>
                        </div>
                        <input type="hidden" name="videoId" value="<%= encodeURIComponent(code) %>">
                        <div class="col-auto">
                            <button type="submit" class="btn btn-secondary btn-sm">Taguer</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Barre Latérale (Suggestions) -->
            <div class="col-lg-4 sidebar">
                <h5 class="mb-3">Vidéos suggérées</h5>
                <% 
                    let suggestions = [];
                    if (typeof nextVideo !== 'undefined' && nextVideo) {
                        suggestions.push(nextVideo);
                    }

                    const otherVideos = videos
                        .filter(v => v.yid !== code && (!nextVideo || v.yid !== (nextVideo.id || nextVideo.yid)))
                        .sort(() => Math.random() - 0.5);
                    
                    suggestions = suggestions.concat(otherVideos).slice(0, 5);

                    suggestions.forEach(function(v) { 
                %>
                    <div class="suggestion-card d-flex align-items-center justify-content-between w-100">
                        <a class="d-flex text-decoration-none" style="flex: 1; min-width: 0; color: inherit;" href="/watch?id=<%= v.yid %>">
                            <img src="/thumbnail/<%= v.yid %>" loading="lazy" class="suggestion-thumb" alt="<%= v.fileName %>">
                            <div class="suggestion-info" style="min-width: 0;">
                                <span class="suggestion-title" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block;" title="<%= v.fileName %>"><%= v.fileName %></span>
                                <span class="suggestion-channel">Voir la vidéo</span>
                            </div>
                        </a>
                        <button onclick="addToQueue('<%= v.yid %>')" class="btn btn-outline-success btn-sm ms-2" title="Ajouter à la file">
                            +
                        </button>
                    </div>
                <% }); %>
                
                <div class="mt-4 pt-4 border-top border-secondary" id="relatedYoutubeContainer">
                    <h5 class="mb-3">Vidéos similaires (YouTube)</h5>
                    <div id="relatedYoutubeLoading" class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <span class="ms-2 text-muted" style="font-size: 0.85rem;">Recherche sur YouTube...</span>
                    </div>
                    <div id="relatedYoutubeList" class="d-flex flex-column gap-2"></div>
                </div>
                
                <div class="mt-4 pt-4 border-top border-secondary" id="remixesYoutubeContainer">
                    <h5 class="mb-3">Remixes (YouTube)</h5>
                    <div id="remixesYoutubeLoading" class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <span class="ms-2 text-muted" style="font-size: 0.85rem;">Recherche de remixes...</span>
                    </div>
                    <div id="remixesYoutubeList" class="d-flex flex-column gap-2"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap & Plyr JS -->
    <script src="/bootstrap.bundle.min.js"></script>
    <script src="/plyr.polyfilled.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const videoId = <%- JSON.stringify(code) %>;
            const positionKey = `video_pos_${videoId}`;
            const lastUrlKey = 'last_visited_url';
            const sessionNavKey = 'has_navigated_this_session';
            
            // Sauvegarder l'URL actuelle et marquer la session
            localStorage.setItem(lastUrlKey, window.location.href);
            sessionStorage.setItem(sessionNavKey, 'true');

            const player = new Plyr('#videoPlayer', {
                autoplay: true,
                invertTime: false,
                toggleInvert: true,
                keyboard: { focused: true, global: true },
            });

            // Reprendre à la position sauvegardée
            player.on('ready', () => {
                const savedPosition = localStorage.getItem(positionKey);
                if (savedPosition) {
                    player.currentTime = parseFloat(savedPosition);
                }
            });

            // Sauvegarder la position
            player.on('timeupdate', () => {
                if (player.currentTime > 0) {
                    localStorage.setItem(positionKey, player.currentTime);
                }
            });

            // Raccourcis clavier YouTube
            document.addEventListener('keydown', (e) => {
                // Ne pas déclencher si on est dans un input
                if (['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return;

                const key = e.key.toLowerCase();
                
                switch(key) {
                    case 'k':
                    case ' ':
                        e.preventDefault();
                        player.togglePlay();
                        break;
                    case 'f':
                        e.preventDefault();
                        player.fullscreen.toggle();
                        break;
                    case 'm':
                        e.preventDefault();
                        player.muted = !player.muted;
                        break;
                    case 'j':
                        e.preventDefault();
                        player.rewind(10);
                        break;
                    case 'l':
                        e.preventDefault();
                        player.forward(10);
                        break;
                    case 'arrowleft':
                        e.preventDefault();
                        player.rewind(5);
                        break;
                    case 'arrowright':
                        e.preventDefault();
                        player.forward(5);
                        break;
                    case 'arrowup':
                        e.preventDefault();
                        player.volume += 0.05;
                        break;
                    case 'arrowdown':
                        e.preventDefault();
                        player.volume -= 0.05;
                        break;
                    case 'n':
                        if (e.shiftKey) { // YouTube shortcut: Shift + N
                            e.preventDefault();
                            playNext();
                        }
                        break;
                }

                // Touches 0-9 pour le pourcentage
                if (/^[0-9]$/.test(key)) {
                    e.preventDefault();
                    const percentage = parseInt(key) * 10;
                    player.currentTime = player.duration * (percentage / 100);
                }
            });

            // Autoplay next video
            document.getElementById('videoPlayer').addEventListener('ended', function() {
                playNext();
            });

            function escapeHTML(str) {
                if (!str) return '';
                return str.replace(/[&<>'"]/g, 
                    tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
                );
            }

            function createYoutubeSuggestionCard(v) {
                let thumbUrl = `https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`;
                if (v.thumbnails && v.thumbnails.length > 0) {
                    thumbUrl = v.thumbnails[v.thumbnails.length - 1].url;
                }
                let durStr = '';
                if (v.duration) {
                    const min = Math.floor(v.duration / 60);
                    const sec = Math.floor(v.duration % 60);
                    durStr = `${min}:${sec < 10 ? '0' : ''}${sec}`;
                }
                
                const card = document.createElement('div');
                card.className = 'suggestion-card d-flex align-items-center justify-content-between w-100';
                card.style.cursor = 'default';
                card.innerHTML = `
                    <a class="d-flex text-decoration-none" style="flex: 1; min-width: 0; color: inherit;" href="/watch?id=${encodeURIComponent(v.id)}">
                        <div class="position-relative flex-shrink-0">
                            <img src="${thumbUrl}" class="suggestion-thumb" alt="${escapeHTML(v.title)}">
                            ${durStr ? `<span class="position-absolute bottom-0 end-0 bg-dark text-white px-1 rounded" style="font-size: 0.65rem; margin: 2px; opacity: 0.85;">${durStr}</span>` : ''}
                        </div>
                        <div class="suggestion-info" style="min-width: 0;">
                            <span class="suggestion-title" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block;" title="${escapeHTML(v.title)}">${escapeHTML(v.title)}</span>
                            <span class="suggestion-channel" style="font-size: 0.75rem; color: #aaaaaa;">${escapeHTML(v.uploader || v.channel || 'YouTube')}</span>
                        </div>
                    </a>
                    <button class="btn btn-outline-success btn-sm ms-2" title="Télécharger">
                        📥
                    </button>
                `;
                
                const downloadBtn = card.querySelector('button');
                downloadBtn.addEventListener('click', () => {
                    downloadYoutubeVideo(v.id);
                });
                
                return card;
            }

            // Charger les vidéos similaires de YouTube de manière asynchrone
            const videoTitle = <%- JSON.stringify(typeof videodata !== 'undefined' && videodata.title ? videodata.title : '') %>;
            const videoUploader = <%- JSON.stringify(typeof videodata !== 'undefined' && videodata.uploader ? videodata.uploader : '') %>;
            if (videoTitle) {
                fetch(`/api/related?title=${encodeURIComponent(videoTitle)}&uploader=${encodeURIComponent(videoUploader)}`)
                    .then(r => r.json())
                    .then(data => {
                        const loader = document.getElementById('relatedYoutubeLoading');
                        const list = document.getElementById('relatedYoutubeList');
                        if (loader) loader.style.display = 'none';
                        if (!list) return;

                        if (data && data.length > 0) {
                            data.forEach(v => {
                                list.appendChild(createYoutubeSuggestionCard(v));
                            });
                        } else {
                            list.innerHTML = '<div class="text-center text-muted py-2" style="font-size: 0.8rem;">Aucune vidéo similaire trouvée.</div>';
                        }
                    })
                    .catch(err => {
                        console.error("Erreur chargement vidéos similaires:", err);
                        const loader = document.getElementById('relatedYoutubeLoading');
                        if (loader) loader.innerHTML = '<span class="text-danger" style="font-size: 0.8rem;">Erreur de chargement</span>';
                    });

                // Charger les remixes de YouTube de manière asynchrone
                fetch(`/api/remixes?title=${encodeURIComponent(videoTitle)}`)
                    .then(r => r.json())
                    .then(data => {
                        const loader = document.getElementById('remixesYoutubeLoading');
                        const list = document.getElementById('remixesYoutubeList');
                        if (loader) loader.style.display = 'none';
                        if (!list) return;

                        if (data && data.length > 0) {
                            data.forEach(v => {
                                list.appendChild(createYoutubeSuggestionCard(v));
                            });
                        } else {
                            list.innerHTML = '<div class="text-center text-muted py-2" style="font-size: 0.8rem;">Aucun remix trouvé.</div>';
                        }
                    })
                    .catch(err => {
                        console.error("Erreur chargement remixes:", err);
                        const loader = document.getElementById('remixesYoutubeLoading');
                        if (loader) loader.innerHTML = '<span class="text-danger" style="font-size: 0.8rem;">Erreur de chargement</span>';
                    });
            }

            // Exposé pour le debug si besoin
            window.player = player;
        });

        async function playNext() {
            const nextId = '<%= (typeof nextVideo !== "undefined" && nextVideo) ? (nextVideo.id || nextVideo.yid) : "" %>';
            const playlistParam = '<%= (typeof playlistName !== 'undefined' && playlistName) ? "&playlist=" + encodeURIComponent(playlistName).replace(/'/g, "%27") : "" %>';
            const currentInQueue = <%= typeof currentInQueue !== 'undefined' ? currentInQueue : 'false' %>;
            
            if (currentInQueue) {
                try {
                    await fetch(`/queue/remove?id=<%= encodeURIComponent(code) %>`, { headers: { 'Accept': 'application/json' } });
                } catch(e) {
                    console.error("Erreur suppression file :", e);
                }
            }

            if (nextId) {
                window.location.href = `/watch?id=${nextId}${playlistParam}`;
            } else if (currentInQueue) {
                // Si on était dans la file et qu'il n'y a pas de vidéo suivante, on retourne à l'accueil
                window.location.href = '/';
            }
        }

        async function shareVideo(url) {
            try {
                await navigator.clipboard.writeText(url);
                const shareBtn = document.activeElement;
                const originalText = shareBtn.textContent;
                shareBtn.textContent = '✓ Copié !';
                shareBtn.classList.replace('btn-outline-info', 'btn-info');
                setTimeout(() => {
                    shareBtn.textContent = originalText;
                    shareBtn.classList.replace('btn-info', 'btn-outline-info');
                }, 2000);
            } catch (err) {
                alert("Lien YouTube : " + url);
            }
        }

        function downloadYoutubeVideo(id) {
            const url = `https://www.youtube.com/watch?v=${id}`;
            if (window.electronAPI && window.electronAPI.setTitle) {
                window.electronAPI.setTitle(url);
                showToast('Téléchargement', 'Téléchargement lancé avec succès !', 'primary');
            } else {
                window.location.href = `/download?url=${encodeURIComponent(url)}`;
            }
        }

        // Le téléchargement est géré par renderer.js via IPC.
        // On peut ajouter un fallback au cas où renderer.js ne se charge pas correctement.
        const commandForm = document.getElementById('commandForm');
        commandForm.addEventListener('submit', (e) => {
            // Si window.electronAPI n'existe pas, on utilise la route Express classique
            if (!window.electronAPI) {
                e.preventDefault();
                const url = document.getElementById('commandInput').value;
                window.location.href = `/download?url=${encodeURIComponent(url)}`;
            }
        });
    </script>

    <!-- Tawk.to removed (offline mode) -->
</body>
</html>

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Plyr CSS -->
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">

    <script src="https://cdn.lr-ingest.com/LogRocket.min.js" crossorigin="anonymous"></script>
    <script>window.LogRocket && window.LogRocket.init('kw8sds/youtube-zozss');</script>
    <script src="renderer.js"></script>
    <script src="socket.io.js"></script>

    <script>
        // Socket.io initialization
        if (typeof io !== 'undefined') {
            const socket = io();
            socket.on('error-notification', (data) => {
                alert("Erreur : " + data.message);
            });
        }
    </script>

    <style>
        :root {
            --bg-color: #0f0f0f;
            --text-color: #f1f1f1;
            --border-color: #3f3f3f;
            --hover-bg: #272727;
            --accent-color: #3ea6ff;
            --plyr-color-main: #ff0000;
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            overflow-x: hidden;
        }
        ::-webkit-scrollbar {
            width: 10px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-color);
        }
        ::-webkit-scrollbar-thumb {
            background: #555;
            border-radius: 5px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #777;
        }
        .navbar {
            background-color: rgba(15, 15, 15, 0.9) !important;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
        }
        .video-container {
            margin-top: 20px;
        }
        .video-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-top: 15px;
            margin-bottom: 10px;
        }
        .video-meta {
            font-size: 0.9rem;
            color: #aaaaaa;
            margin-bottom: 15px;
        }
        .video-description {
            background-color: var(--hover-bg);
            padding: 15px;
            border-radius: 12px;
            font-size: 0.95rem;
            white-space: pre-wrap;
            border: 1px solid transparent;
            transition: border-color 0.2s;
        }
        .video-description:hover {
            border-color: var(--border-color);
        }
        .sidebar {
            padding-left: 20px;
        }
        .suggestion-card {
            display: flex;
            margin-bottom: 12px;
            text-decoration: none;
            color: inherit;
            transition: transform 0.2s ease, background-color 0.2s;
            padding: 6px;
            border-radius: 10px;
        }
        .suggestion-card:hover {
            background-color: var(--hover-bg);
            transform: translateY(-2px);
        }
        .suggestion-thumb {
            width: 168px;
            height: 94px;
            object-fit: cover;
            border-radius: 8px;
            margin-right: 12px;
        }
        .suggestion-info {
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }
        .suggestion-title {
            font-size: 0.95rem;
            font-weight: 500;
            line-height: 1.3rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            transition: color 0.2s;
        }
        .suggestion-card:hover .suggestion-title {
            color: var(--accent-color);
        }
        .suggestion-channel {
            font-size: 0.85rem;
            color: #aaaaaa;
            margin-top: 4px;
        }
        .nav-link-custom {
            color: var(--text-color);
            text-decoration: none;
            margin-right: 15px;
            font-size: 0.9rem;
            transition: color 0.2s;
        }
        .nav-link-custom:hover {
            color: var(--accent-color);
        }
        .search-container {
            max-width: 600px;
        }
        .form-control {
            background-color: #121212;
            border: 1px solid var(--border-color);
            color: var(--text-color);
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-control:focus {
            background-color: #121212;
            border-color: var(--accent-color);
            color: white;
            box-shadow: 0 0 0 3px rgba(62, 166, 255, 0.2);
        }
        .btn-outline-light {
            border-color: var(--border-color);
            color: var(--text-color);
        }
        .btn-outline-light:hover {
            background-color: var(--hover-bg);
            border-color: #555;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top mb-4">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="https://www.youtube.com/favicon.ico" width="30" height="30" class="me-2" alt="">
                <div class="d-flex flex-column">
                    <strong>YouTube Downloader</strong>
                    <span style="font-size: 0.65rem; color: #aaaaaa; margin-top: -5px;">v<%= typeof appVersion !== 'undefined' ? appVersion : '' %></span>
                </div>
            </a>
            
            <div class="d-flex flex-grow-1 justify-content-center mx-4">
                <form id="commandForm" class="d-flex w-100 search-container m-0 flex-column">
                    <div class="d-flex w-100">
                        <input class="form-control me-2 rounded-pill ps-4" type="text" id="commandInput" placeholder="Coller une URL YouTube..." required>
                        <button class="btn btn-outline-light rounded-pill px-4" type="submit">Télécharger</button>
                    </div>
                    <small class="text-muted text-center mt-1" style="font-size: 0.65rem; color: #777 !important;">Fichier backlog : <%= typeof backlogFile !== 'undefined' ? backlogFile : '' %></small>
                </form>
            </div>
            <div class="d-flex">
                <a href="/favorites" class="btn btn-outline-danger rounded-pill px-4 me-2">Favoris (<%= typeof favoritesCount !== 'undefined' ? favoritesCount : 0 %>)</a>
                <a href="/queue" class="btn btn-outline-success rounded-pill px-4 me-2">File (<%= typeof queueCount !== 'undefined' ? queueCount : 0 %>)</a>
                <a href="/playlists" class="btn btn-outline-warning rounded-pill px-4 me-2">Playlists</a>
                <a href="/history" class="btn btn-outline-info rounded-pill px-4">Historique (<%= typeof historyCount !== 'undefined' ? historyCount : 0 %>/<%= typeof historyLimit !== 'undefined' ? historyLimit : 0 %>)</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid video-container">
        <div class="row">
            <!-- Lecteur Vidéo et Infos -->
            <div class="col-lg-8">
                <div class="plyr__video-embed" id="player">
                    <video id="videoPlayer" controls crossorigin playsinline>
                        <source src="/video/?id=<%= encodeURIComponent(code) %>" type="video/mp4" />
                    </video>
                </div>

                <h1 class="video-title"><%= (typeof videodata !== 'undefined' && videodata.title) ? videodata.title : title %></h1>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="video-meta">
                        <strong><a href="/channel?name=<%= (typeof videodata !== 'undefined' && videodata.uploader) ? encodeURIComponent(videodata.uploader) : '' %>" style="color: #ffffff; text-decoration: none;"><%= (typeof videodata !== 'undefined' && videodata.uploader) ? videodata.uploader : 'Uploader inconnu' %></a></strong> • <%= (typeof videodata !== 'undefined' && videodata.view_count) ? videodata.view_count.toLocaleString() + ' vues' : '' %>
                    </div>
                    <div class="d-flex align-items-center">
                        <button id="favoriteBtn" class="btn <%= isFavorite ? 'btn-danger' : 'btn-outline-danger' %> btn-sm me-2" onclick="toggleFavorite(<%- JSON.stringify(code).replace(/\"/g, '&quot;') %>)">
                            <%= isFavorite ? '❤' : '♡' %> Favori
                        </button>
                        <button class="btn btn-outline-info btn-sm me-2" onclick='shareVideo(<%- JSON.stringify((typeof videodata !== 'undefined' && videodata.webpage_url) ? videodata.webpage_url : ('https://www.youtube.com/watch?v=' + code)) %>)'>
                            ↗ Partager
                        </button>
                        <button class="btn btn-outline-success btn-sm me-2" onclick='addToQueue(<%- JSON.stringify(code) %>)'>File d'attente</button>
                        <% if (typeof videodata !== 'undefined' && (videodata.channel_url || videodata.uploader_url)) { %>
                            <button class="btn btn-outline-primary btn-sm me-2" onclick="downloadChannel('<%= (videodata.channel_url || videodata.uploader_url).replace(/'/g, "\\'") %>')">
                                📥 Télécharger la chaîne
                            </button>
                        <% } %>
                        <div class="dropdown me-2">
                            <button class="btn btn-outline-warning btn-sm dropdown-toggle" type="button" id="playlistDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                Ajouter à une playlist
                            </button>
                            <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="playlistDropdown">
                                <% playlists.forEach(function(playlist) { %>
                                    <li>
                                        <form action="/playlist/add" method="POST">
                                            <input type="hidden" name="playlistName" value="<%= playlist.name %>">
                                            <input type="hidden" name="videoId" value="<%= code %>">
                                            <button type="submit" class="dropdown-item"><%= playlist.name %></button>
                                        </form>
                                    </li>
                                <% }); %>
                                <% if (playlists.length === 0) { %>
                                    <li><a class="dropdown-item disabled" href="#">Aucune playlist</a></li>
                                <% } %>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/playlists">Gérer les playlists</a></li>
                            </ul>
                        </div>
                        <% if (typeof nextVideo !== 'undefined' && nextVideo) { %>
                            <button onclick="playNext()" class="btn btn-outline-primary btn-sm me-2">Vidéo suivante</button>
                        <% } %>
                        <a href="/delete?id=<%= encodeURIComponent(code) %>" class="btn btn-outline-danger btn-sm">Supprimer</a>
                    </div>
                </div>

                <div class="video-description">
                    <p><%= (typeof videodata !== 'undefined') ? videodata.description : '' %></p>
                </div>

                <div class="mt-4">
                    <h5>Ajouter un tag</h5>
                    <form action="/tag" method="post" class="row g-3">
                        <div class="col-auto">
                            <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" id="tagInput" name="tag" placeholder="Tag..." required>
                        </div>
                        <input type="hidden" name="videoId" value="<%= encodeURIComponent(code) %>">
                        <div class="col-auto">
                            <button type="submit" class="btn btn-secondary btn-sm">Taguer</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Barre Latérale (Suggestions) -->
            <div class="col-lg-4 sidebar">
                <h5 class="mb-3">Vidéos suggérées</h5>
                <% 
                    let suggestions = [];
                    if (typeof nextVideo !== 'undefined' && nextVideo) {
                        suggestions.push(nextVideo);
                    }

                    const otherVideos = videos
                        .filter(v => v.yid !== code && (!nextVideo || v.yid !== (nextVideo.id || nextVideo.yid)))
                        .sort(() => Math.random() - 0.5);
                    
                    suggestions = suggestions.concat(otherVideos).slice(0, 5);

                    suggestions.forEach(function(v) { 
                %>
                    <a href="/watch?id=<%= v.yid %>" class="suggestion-card d-flex align-items-center justify-content-between w-100">
                        <div class="d-flex">
                            <img src="https://img.youtube.com/vi/<%= v.yid %>/hqdefault.jpg" class="suggestion-thumb" alt="<%= v.fileName %>">
                            <div class="suggestion-info">
                                <span class="suggestion-title"><%= v.fileName %></span>
                                <span class="suggestion-channel">Voir la vidéo</span>
                            </div>
                        </div>
                        <button onclick="event.preventDefault(); event.stopPropagation(); addToQueue('<%= v.yid %>')" class="btn btn-outline-success btn-sm ms-2" title="Ajouter à la file">
                            +
                        </button>
                    </a>
                <% }); %>
            </div>
        </div>
    </div>

    <!-- Bootstrap & Plyr JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const videoId = <%- JSON.stringify(code) %>;
            const positionKey = `video_pos_${videoId}`;
            const lastUrlKey = 'last_visited_url';
            const sessionNavKey = 'has_navigated_this_session';
            
            // Sauvegarder l'URL actuelle et marquer la session
            localStorage.setItem(lastUrlKey, window.location.href);
            sessionStorage.setItem(sessionNavKey, 'true');

            const player = new Plyr('#videoPlayer', {
                autoplay: true,
                invertTime: false,
                toggleInvert: true,
                keyboard: { focused: true, global: true },
            });

            // Reprendre à la position sauvegardée
            player.on('ready', () => {
                const savedPosition = localStorage.getItem(positionKey);
                if (savedPosition) {
                    player.currentTime = parseFloat(savedPosition);
                }
            });

            // Sauvegarder la position
            player.on('timeupdate', () => {
                if (player.currentTime > 0) {
                    localStorage.setItem(positionKey, player.currentTime);
                }
            });

            // Raccourcis clavier YouTube
            document.addEventListener('keydown', (e) => {
                // Ne pas déclencher si on est dans un input
                if (['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return;

                const key = e.key.toLowerCase();
                
                switch(key) {
                    case 'k':
                    case ' ':
                        e.preventDefault();
                        player.togglePlay();
                        break;
                    case 'f':
                        e.preventDefault();
                        player.fullscreen.toggle();
                        break;
                    case 'm':
                        e.preventDefault();
                        player.muted = !player.muted;
                        break;
                    case 'j':
                        e.preventDefault();
                        player.rewind(10);
                        break;
                    case 'l':
                        e.preventDefault();
                        player.forward(10);
                        break;
                    case 'arrowleft':
                        e.preventDefault();
                        player.rewind(5);
                        break;
                    case 'arrowright':
                        e.preventDefault();
                        player.forward(5);
                        break;
                    case 'arrowup':
                        e.preventDefault();
                        player.volume += 0.05;
                        break;
                    case 'arrowdown':
                        e.preventDefault();
                        player.volume -= 0.05;
                        break;
                    case 'n':
                        if (e.shiftKey) { // YouTube shortcut: Shift + N
                            e.preventDefault();
                            playNext();
                        }
                        break;
                }

                // Touches 0-9 pour le pourcentage
                if (/^[0-9]$/.test(key)) {
                    e.preventDefault();
                    const percentage = parseInt(key) * 10;
                    player.currentTime = player.duration * (percentage / 100);
                }
            });

            // Autoplay next video
            document.getElementById('videoPlayer').addEventListener('ended', function() {
                playNext();
            });

            // Exposé pour le debug si besoin
            window.player = player;
        });

        async function playNext() {
            const nextId = '<%= (typeof nextVideo !== 'undefined') ? (nextVideo.id || nextVideo.yid) : '' %>';
            const playlistParam = '<%= (typeof playlistName !== 'undefined' && playlistName) ? "&playlist=" + encodeURIComponent(playlistName).replace(/'/g, "%27") : "" %>';
            const currentInQueue = <%= typeof currentInQueue !== 'undefined' ? currentInQueue : 'false' %>;
            
            if (currentInQueue) {
                try {
                    await fetch(`/queue/remove?id=<%= encodeURIComponent(code) %>`, { headers: { 'Accept': 'application/json' } });
                } catch(e) {
                    console.error("Erreur suppression file :", e);
                }
            }

            if (nextId) {
                window.location.href = `/watch?id=${nextId}${playlistParam}`;
            } else if (currentInQueue) {
                // Si on était dans la file et qu'il n'y a pas de vidéo suivante, on retourne à l'accueil
                window.location.href = '/';
            }
        }

        async function addToQueue(videoId) {
            try {
                const response = await fetch(`/queue/add?id=${videoId}`, {
                    headers: { 'Accept': 'application/json' }
                });
                const data = await response.json();
                if (data.success) {
                    const queueBtn = document.querySelector('a[href="/queue"]');
                    if (queueBtn) {
                        queueBtn.textContent = `File (${data.queueCount})`;
                    }
                }
            } catch (err) {
                console.error("Erreur ajout file :", err);
            }
        }

        async function toggleFavorite(videoId) {
            try {
                const response = await fetch(`/favorite/toggle?id=${videoId}`, {
                    headers: { 'Accept': 'application/json' }
                });
                const data = await response.json();
                if (data.success) {
                    const favBtn = document.getElementById('favoriteBtn');
                    const favNavBtn = document.querySelector('a[href="/favorites"]');
                    
                    if (favNavBtn) {
                        favNavBtn.textContent = `Favoris (${data.favoritesCount})`;
                    }

                    if (data.isFavorite) {
                        favBtn.classList.remove('btn-outline-danger');
                        favBtn.classList.add('btn-danger');
                        favBtn.textContent = '❤ Favori';
                    } else {
                        favBtn.classList.remove('btn-danger');
                        favBtn.classList.add('btn-outline-danger');
                        favBtn.textContent = '♡ Favori';
                    }
                }
            } catch (err) {
                console.error("Erreur toggle favori :", err);
            }
        }

        async function shareVideo(url) {
            try {
                await navigator.clipboard.writeText(url);
                const shareBtn = document.activeElement;
                const originalText = shareBtn.textContent;
                shareBtn.textContent = '✓ Copié !';
                shareBtn.classList.remove('btn-outline-info');
                shareBtn.classList.add('btn-info');
                
                setTimeout(() => {
                    shareBtn.textContent = originalText;
                    shareBtn.classList.remove('btn-info');
                    shareBtn.classList.add('btn-outline-info');
                }, 2000);
            } catch (err) {
                console.error("Erreur partage :", err);
                alert("Lien YouTube : " + url);
            }
        }

        function downloadChannel(url) {
            if (window.electronAPI && window.electronAPI.setTitle) {
                window.electronAPI.setTitle(url);
                alert("Téléchargement de la chaîne lancé !");
            } else {
                window.location.href = `/download?url=${encodeURIComponent(url)}`;
            }
        }

        // Le téléchargement est géré par renderer.js via IPC.
        // On peut ajouter un fallback au cas où renderer.js ne se charge pas correctement.
        const commandForm = document.getElementById('commandForm');
        commandForm.addEventListener('submit', (e) => {
            // Si window.electronAPI n'existe pas, on utilise la route Express classique
            if (!window.electronAPI) {
                e.preventDefault();
                const url = document.getElementById('commandInput').value;
                window.location.href = `/download?url=${encodeURIComponent(url)}`;
            }
        });
    </script>

    <!-- Tawk.to Script -->
    <script type="text/javascript">
        var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
        (function(){
            var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
            s1.async=true;
            s1.src='https://embed.tawk.to/673f4ae72480f5b4f5a1dbce/1id7jp68o';
            s1.charset='UTF-8';
            s1.setAttribute('crossorigin','*');
            s0.parentNode.insertBefore(s1,s0);
        })();
    </script>
</body>
</html>
